{
  "name": "hooman",
  "productName": "Hooman",
  "private": true,
  "version": "0.1.4",
  "description": "Hooman — HRM desktop for Windows (Electron + React + MySQL)",
  "repository": {
    "type": "git",
    "url": "https://github.com/nervaotics/Hooman.git"
  },
  "author": "",
  "license": "UNLICENSED",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c cyan,magenta \"vite --host 127.0.0.1 --port 5173 --strictPort\" \"wait-on http://127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:vite": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "preview": "vite preview",
    "lint": "eslint .",
    "migrate": "node electron/db/run-migrations.cjs",
    "release": "npm run build && electron-builder --win --publish always",
    "release:patch": "node scripts/release.cjs patch",
    "release:minor": "node scripts/release.cjs minor",
    "release:major": "node scripts/release.cjs major",
    "release:push": "node scripts/release.cjs patch --push",
    "postinstall": "node scripts/ensure-electron.cjs",
    "electron:install": "node node_modules/electron/install.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.6.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "lucide-react": "^0.525.0",
    "mysql2": "^3.14.0",
    "node-cron": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.58.1",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.0.2",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.3.1",
    "zklib": "^0.2.11",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "eslint": "^10.3.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.12",
    "wait-on": "^8.0.4"
  }
}
