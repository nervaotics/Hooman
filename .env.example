NODE_ENV=development

# Central MySQL (overridden per workstation via Hooman Settings)
DB_HOST=127.0.0.1
DB_PORT=Your_DB_port_here
DB_USER=root
DB_PASS=
DB_NAME=hooman_hrm

# Auth
JWT_SECRET=

# Organization display timezone (Asia/Karachi)
ORG_TZ=Asia/Karachi

# ZKTeco poll interval (minutes) — poller currently fixed at 5 minutes in code
ZKTECO_POLL_INTERVAL=5
