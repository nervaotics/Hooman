NODE_ENV=development

# Supabase (optional dev defaults — workstation setup wizard overrides these)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_DB_PASSWORD=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth
JWT_SECRET=

# Organization display timezone (Asia/Karachi)
ORG_TZ=Asia/Karachi

# ZKTeco poll interval (minutes) — poller currently fixed at 5 minutes in code
ZKTECO_POLL_INTERVAL=5

# One-time MySQL → Supabase migration script only (scripts/migrate-mysql-to-supabase.cjs)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASS=
MYSQL_DB=hooman_hrm
SUPABASE_PROJECT_REF=
